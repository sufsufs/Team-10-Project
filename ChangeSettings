<!DOCTYPE html>
<!-- Written by Heather Stephens -->
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>User Profile Settings</title>
    <style>
        /* Basic styling for the body */
        body {
            font-family: Arial, sans-serif;
            background-color: #f4f4f4;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
        }

        /* Styling for the container div */
        .container {
            background-color: #fff;
            padding: 20px;
            border-radius: 5px;
            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
        }

        /* Styling for the heading */
        h1 {
            margin-bottom: 20px;
        }

        /* Styling for the form */
        form {
            display: flex;
            flex-direction: column;
        }

        /* Styling for the labels */
        label {
            margin-bottom: 5px;
        }

        /* Styling for the input fields and select dropdown */
        input, select {
            margin-bottom: 15px;
            padding: 10px;
            border: 1px solid #ccc;
            border-radius: 3px;
        }

        /* Styling for the submit button */
        button {
            padding: 10px;
            background-color: #28a745;
            color: #fff;
            border: none;
            border-radius: 3px;
            cursor: pointer;
        }

        /* Styling for the submit button on hover */
        button:hover {
            background-color: #218838;
        }

        /* Styling for the error messages */
        .error {
            color: red;
            margin-bottom: 15px;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>Profile Settings</h1>
        <form id="profileForm">
            <!-- Container for error messages -->
            <div id="errorContainer" class="error"></div>

            <!-- Username input field -->
            <label for="username">Username:</label>
            <input type="text" id="username" name="username" required>

            <!-- Email input field -->
            <label for="email">Email:</label>
            <input type="email" id="email" name="email" required>

            <!-- Password input field -->
            <label for="password">Password:</label>
            <input type="password" id="password" name="password" required>

            <!-- Preferred language dropdown -->
            <label for="language">Preferred Language:</label>
            <select id="language" name="language" required>
                <option value="en">English</option>
                <option value="es">Spanish</option>
                <option value="fr">French</option>
                <option value="de">German</option>
                <option value="zh">Chinese</option>
                <!-- Add more languages as needed -->
            </select>

            <!-- Submit button -->
            <button type="submit">Save Changes</button>
        </form>
    </div>
    <script>
        // Add event listener for form submission
        document.getElementById('profileForm').addEventListener('submit', function(event) {
            event.preventDefault(); // Prevent default form submission

            // Get values from input fields
            const username = document.getElementById('username').value;
            const email = document.getElementById('email').value;
            const password = document.getElementById('password').value;
            const language = document.getElementById('language').value;

            let errorMessages = []; // Array to hold error messages

            // Validate username
            if (username.length < 3) {
                errorMessages.push('Username must be at least 3 characters long.');
            }

            // Validate email using regex pattern
            const emailPattern = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
            if (!emailPattern.test(email)) {
                errorMessages.push('Please enter a valid email address.');
            }

            // Validate password
            if (password.length < 6) {
                errorMessages.push('Password must be at least 6 characters long.');
            }

            // Validate language selection
            if (!language) {
                errorMessages.push('Please select a preferred language.');
            }

            // Get the error container div
            const errorContainer = document.getElementById('errorContainer');
            errorContainer.innerHTML = ''; // Clear previous error messages

            // If there are validation errors, display them
            if (errorMessages.length > 0) {
                errorContainer.innerHTML = errorMessages.join('<br>');
            } else {
                // If no errors, create user data object and log it
                const userData = {
                    username: username,
                    email: email,
                    password: password,
                    language: language
                };

                console.log('User Data:', userData);
                alert('Profile updated successfully!'); // Show success message
            }
        });
    </script>
</body>
</html>
